# Public site URL used for canonical links, callbacks, and emails.
NEXT_PUBLIC_SITE_URL="https://pocket-cosmos.com"

# Supabase overseas backend.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVER_ONLY_SERVICE_ROLE_KEY"

# Server-side AI provider keys. Never expose these to the browser.
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
GOOGLE_GENERATIVE_AI_API_KEY="YOUR_GEMINI_API_KEY"

# Payments and booking providers.
STRIPE_SECRET_KEY="YOUR_STRIPE_SECRET_KEY"
STRIPE_WEBHOOK_SECRET="YOUR_STRIPE_WEBHOOK_SECRET"
CALENDAR_PROVIDER_API_KEY="YOUR_CALENDAR_PROVIDER_API_KEY"
